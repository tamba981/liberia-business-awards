# Prevent directory listing
Options -Indexes

# Protect sensitive directories
<FilesMatch "\.(json|env|log|sql|bak|config)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Force HTTPS (if you have SSL)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Block access to .git directories
RedirectMatch 404 /\.git

# Protect admin directory - require valid session (for server-side)
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirect direct access to admin/index.html without proper referer
    RewriteCond %{REQUEST_URI} ^/dashboard/admin/
    RewriteCond %{HTTP_REFERER} !^https?://[^/]+/dashboard/login\.html
    RewriteRule ^ - [F]
    
    # Redirect direct access to business/index.html without proper referer
    RewriteCond %{REQUEST_URI} ^/dashboard/business/
    RewriteCond %{HTTP_REFERER} !^https?://[^/]+/dashboard/login\.html
    RewriteRule ^ - [F]
</IfModule>
